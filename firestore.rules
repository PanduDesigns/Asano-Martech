rules_version = '2';

// ============================================================================
// Reglas de seguridad de Firestore para Asano.
//
// Modelo: equipo pequeño y de confianza (6-15 personas) donde TODO el
// departamento debe ver todos los proyectos y tareas — no hay privacidad
// entre compañeros dentro de la herramienta. memberIds se sigue guardando
// en cada proyecto de forma informativa (quién lo creó/participa) pero ya
// NO se usa para filtrar quién puede leer.
//
//  - meta/bootstrap: documento centinela. La primera persona en registrarse
//    lo crea y se convierte en "admin"; el resto queda como "miembro".
//  - meta/config: ajustes del equipo (p.ej. dominios de correo permitidos).
//    Solo lectura para todos, escritura solo para admins.
//  - users/{uid}: perfil de cada persona. Cualquiera autenticado puede leer
//    la lista (para asignar tareas); solo un admin puede cambiar el rol de
//    otra persona.
//  - projects/{id}: cualquier persona autenticada puede leer, crear y
//    editar cualquier proyecto. Solo quien lo creó (o un admin) puede
//    borrarlo.
//  - tasks/{id}: igual que proyectos si tienen projectId (visibles y
//    editables por cualquier persona autenticada del equipo). Si en cambio
//    projectId es null, es una tarea PERSONAL (recordatorio privado en
//    "Mis tareas") y solo la puede ver/editar quien conste como ownerId.
//    Borrado reservado a quien la creó/es su dueño o a un admin.
//  - tasks/{id}/comments/{id}: cualquier miembro del equipo puede comentar;
//    solo el autor o un admin puede editar/borrar un comentario.
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- Bootstrap de administración ----
    match /meta/bootstrap {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // inmutable una vez creado
    }

    match /meta/config {
      // Lectura pública a propósito: solo contiene la lista de dominios de
      // correo permitidos, y hay que poder comprobarla ANTES de crear la
      // cuenta (con la persona todavía sin autenticar).
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Usuarios ----
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId &&
        (request.resource.data.role == 'miembro' ||
         (request.resource.data.role == 'admin' &&
          !exists(/databases/$(database)/documents/meta/bootstrap)));
      allow update: if isSignedIn() &&
        (isAdmin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    // ---- Proyectos (visibles para todo el equipo) ----
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ---- Tareas (de proyecto: visibles para todo el equipo · personales: solo su dueño/a) ----
    match /tasks/{taskId} {
      allow read: if isSignedIn() &&
        (resource.data.projectId != null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
        (request.resource.data.projectId != null || request.resource.data.ownerId == request.auth.uid);
      allow update: if isSignedIn() &&
        (resource.data.projectId != null || resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() &&
        (resource.data.ownerId == request.auth.uid ||
         resource.data.createdBy == request.auth.uid ||
         isAdmin() ||
         (resource.data.projectId != null &&
          get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.createdBy == request.auth.uid));

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }

    // ---- Etiquetas (vocabulario compartido: nombre + color) ----
    match /tags/{tagId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ---- Notificaciones (reservado para la fase 2) ----
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }
  }
}

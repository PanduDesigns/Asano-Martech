rules_version = '2';

// ============================================================================
// Reglas de Firebase Storage — archivos adjuntos de las tareas.
// Cualquier persona autenticada del equipo puede leer y subir archivos
// (límite de 20 MB por archivo). Para un equipo pequeño y de confianza esto
// es suficiente; si más adelante quieres comprobar que la persona sea
// miembro del proyecto concreto antes de subir, se puede añadir una
// llamada a firestore.get() aquí mismo.
// ============================================================================
service firebase.storage {
  match /b/{bucket}/o {
    match /attachments/{taskId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
